{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CTest: Run Debug",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "build",
                "-C",
                "Debug",
                "--output-on-failure"
            ],
            "group": "test",
            "problemMatcher": []
        }
    ]
}
